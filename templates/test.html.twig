{% extends 'base.html.twig' %}

{% block title %}Todo App{% endblock %}

{% block stylesheets %}
    <link href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.3.1/mdb.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 id="page-title">{{ title }}</h1>

        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-success" data-mdb-toggle="modal" data-mdb-target="#addTaskModal">
                Добавить задачу
            </button>
        </div>

        <table class="table table-striped">
            <thead class="thead-dark">
            <tr>
                <th scope="col" class="fw-bold">№</th>
                <th scope="col" class="fw-bold">Название</th>
                <th scope="col" class="fw-bold">Описание</th>
                <th scope="col" class="fw-bold">Статус</th>
                <th scope="col" class="fw-bold">Действия</th>
            </tr>
            </thead>
            <tbody id="task-table-body">
            {% for task in tasks %}
                <tr class="task-item" data-status="{{ task.status }}">
                    <th scope="row">{{ loop.index }}</th>
                    <td class="task-title">{{ task.title }}</td>
                    <td class="task-desc">{{ task.description }}</td>
                    <td>
                    <span class="badge rounded-pill
                        {% if task.status == 1 %}bg-primary{% elseif task.status == 2 %}bg-warning{% else %}bg-success{% endif %}">
                        {% if task.status == 1 %}Новая задача{% elseif task.status == 2 %}В процессе{% else %}Выполнено{% endif %}
                    </span>
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <div class="dropdown task-dropdown"
                                 {% if task.status == 3 %}style="display:none"{% endif %}>
                                <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" data-mdb-toggle="dropdown">
                                    Сменить статус
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item change-status" href="#" data-set-status="2">В процессе</a></li>
                                    <li><a class="dropdown-item change-status" href="#" data-set-status="3">Выполнено</a></li>
                                </ul>
                            </div>
                            <button class="btn btn-sm btn-danger delete-task" type="button">Удалить</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Задач пока нет</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <template id="task-template">
        <tr class="task-item" data-status="1">
            <th scope="row"></th>
            <td class="task-title"></td>
            <td class="task-desc"></td>
            <td><span class="badge rounded-pill bg-primary">Новая задача</span></td>
            <td>
                <div class="d-flex gap-1">
                    <div class="dropdown task-dropdown">
                        <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" data-mdb-toggle="dropdown">
                            Сменить статус
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item change-status" href="#" data-set-status="2">В процессе</a></li>
                            <li><a class="dropdown-item change-status" href="#" data-set-status="3">Выполнено</a></li>
                        </ul>
                    </div>
                    <button class="btn btn-sm btn-danger delete-task" type="button">Удалить</button>
                </div>
            </td>
        </tr>
    </template>

    <div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addTaskModalLabel">Добавить новую задачу</h5>
                    <button type="button" class="btn-close" data-mdb-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="add-task-form">
                        <div class="mb-3">
                            <label for="task-title" class="form-label">Название</label>
                            <input type="text" class="form-control" id="task-title" required>
                            <div class="invalid-feedback" id="title-error"></div>
                        </div>
                        <div class="mb-3">
                            <label for="task-description" class="form-label">Описание</label>
                            <input type="text" class="form-control" id="task-description" required>
                            <div class="invalid-feedback" id="description-error"></div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-mdb-dismiss="modal">Закрыть</button>
                    <button type="button" class="btn btn-success" id="save-task-btn">Добавить</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteConfirmLabel">Подтвердите удаление</h5>
                    <button type="button" class="btn-close" data-mdb-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Вы уверены, что хотите удалить эту задачу?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-mdb-dismiss="modal">Нет</button>
                    <button type="button" class="btn btn-danger" id="confirm-delete-btn">Да, удалить</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.3.1/mdb.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            const tableBody = document.getElementById('task-table-body');
            const saveBtn = document.getElementById('save-task-btn');
            const deleteModalEl = document.getElementById('deleteConfirmModal');
            const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
            const template = document.getElementById('task-template');
            let taskToDelete = null;

            function createTaskRow(task) {
                let tr = template.content.cloneNode(true).querySelector('tr');
                tr.querySelector('.task-title').textContent = task.title;
                tr.querySelector('.task-desc').textContent = task.description;
                tr.dataset.status = 1;

                let dropdown = tr.querySelector('.task-dropdown');
                dropdown.style.display = 'flex'; // новая задача всегда видна

                return tr;
            }

            function updateRowNumbers() {
                let rows = tableBody.querySelectorAll('tr.task-item');
                for (let i = 0; i < rows.length; i++) {
                    rows[i].querySelector('th').textContent = i + 1;
                }
            }

            function changeStatus(tr, status) {
                tr.dataset.status = status;

                let badge = tr.querySelector('.badge');
                let classes = {1:'bg-primary', 2:'bg-warning', 3:'bg-success'};
                let texts = {1:'Новая задача', 2:'В процессе', 3:'Выполнено'};

                badge.className = 'badge rounded-pill ' + classes[status];
                badge.textContent = texts[status];

                let dropdown = tr.querySelector('.task-dropdown');
                if (status === 3) {
                    dropdown.style.display = 'none';
                } else {
                    dropdown.style.display = 'flex';
                }
            }

            function deleteTask(tr) {
                tr.remove();
                updateRowNumbers();
            }

            saveBtn.addEventListener('click', function() {
                let titleInput = document.getElementById('task-title');
                let descInput = document.getElementById('task-description');
                let isValid = true;

                // Очистка ошибок
                document.getElementById('title-error').textContent = '';
                document.getElementById('description-error').textContent = '';
                titleInput.classList.remove('is-invalid');
                descInput.classList.remove('is-invalid');

                // Валидация
                if (!titleInput.value.trim()) {
                    isValid = false;
                    titleInput.classList.add('is-invalid');
                    document.getElementById('title-error').textContent = 'Название обязательно';
                } else if (titleInput.value.trim().length < 3) {
                    isValid = false;
                    titleInput.classList.add('is-invalid');
                    document.getElementById('title-error').textContent = 'Минимум 3 символа';
                }

                if (!descInput.value.trim()) {
                    isValid = false;
                    descInput.classList.add('is-invalid');
                    document.getElementById('description-error').textContent = 'Описание обязательно';
                } else if (descInput.value.trim().length < 3) {
                    isValid = false;
                    descInput.classList.add('is-invalid');
                    document.getElementById('description-error').textContent = 'Минимум 3 символа';
                }

                if (!isValid) return;

                let tr = createTaskRow({title: titleInput.value.trim(), description: descInput.value.trim()});
                tableBody.appendChild(tr);
                updateRowNumbers();
                document.getElementById('add-task-form').reset();

                let modal = mdb.Modal.getInstance(document.getElementById('addTaskModal'));
                modal.hide();
            });

            tableBody.addEventListener('click', function(e) {
                let tr = e.target.closest('tr.task-item');
                if (!tr) return;

                if (e.target.classList.contains('delete-task')) {
                    taskToDelete = tr;
                    let modal = new mdb.Modal(deleteModalEl);
                    modal.show();
                }

                if (e.target.classList.contains('change-status')) {
                    e.preventDefault();
                    let newStatus = parseInt(e.target.dataset.setStatus);
                    changeStatus(tr, newStatus);
                }
            });

            confirmDeleteBtn.addEventListener('click', function() {
                if (taskToDelete) {
                    deleteTask(taskToDelete);
                    taskToDelete = null;
                    let modal = mdb.Modal.getInstance(deleteModalEl);
                    modal.hide();
                }
            });

        });

    </script>
{% endblock %}
